# Copy to .env and fill in. NEVER commit .env or log these values.

# --- LLM provider ---
# groq (free, no org/billing) | anthropic (needs billing/org)
LLM_PROVIDER=groq

# Groq: free key from https://console.groq.com/keys  (OpenAI-compatible API)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic: add later when billing is set up
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Database ---
# Local Postgres, e.g. postgresql+psycopg://localhost:5432/brain_os
DATABASE_URL=postgresql+psycopg://localhost:5432/brain_os

# --- GitHub ---
# Fine-grained PAT scoped to ONLY the test repo: Contents + Pull requests = read/write
GITHUB_TOKEN=
# The repo the agent opens PRs against, e.g. myhandle/agent-sandbox
GITHUB_REPO=
# Base branch to open PRs against
GITHUB_BASE_BRANCH=main

# --- Pre-PR validation ---
# How hard to check generated code BEFORE opening a PR:
#   off  = syntax check only
#   lint = also run ruff pyflakes rules (static; safe default)
#   full = also install deps + run pytest (executes generated code; opt-in)
PREPR_VALIDATION=lint
PREPR_VALIDATION_TIMEOUT=120

# --- Observability ---
# Sentry error tracking (optional). Leave blank to disable.
SENTRY_DSN=
# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Slack (Weekend 2, leave blank for now) ---
SLACK_BOT_TOKEN=

# --- Watchdog pipeline ---
# Secrets for verifying inbound webhook payloads
GITHUB_WEBHOOK_SECRET=     # any string you choose when registering the GitHub webhook
SENTRY_WEBHOOK_SECRET=     # Sentry internal integration → Client Secret

# Who gets assigned when CODEOWNERS has no match
WATCHDOG_DEFAULT_ASSIGNEE= # github username e.g. "aryan"
# Reporter name shown on all watchdog-created tickets (system account)
WATCHDOG_REPORTER=watchdog
# Slack channel for incident notifications (e.g. "#incidents")
WATCHDOG_SLACK_CHANNEL=

# --- Sentry APM (optional) ---
# Enables the get_recent_errors agent tool so it can pull production stack traces
# before writing a fix. Create an internal integration at sentry.io → Settings →
# Integrations → Internal Integration, and copy the token here.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=          # your org slug, e.g. "acme-corp"
SENTRY_PROJECT=      # your project slug, e.g. "backend"
